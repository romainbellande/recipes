---
import { getCollection } from "astro:content";

const tagLabels: Record<string, string> = {
  breakfast: "Petit-déjeuner",
  main: "Plat principal",
  side: "Accompagnement",
  dessert: "Dessert",
  weeknight: "Rapide en semaine",
  "make-ahead": "À préparer à l'avance",
  vegetarian: "Végétarien",
  pantry: "Du placard",
};
const controlledTags = Object.keys(tagLabels);
const durationMinutes = (value: string) => {
  const hours = Number(value.match(/(\d+) h/)?.[1] ?? 0);
  const minutes = Number(value.match(/(\d+) min/)?.[1] ?? 0);
  return hours * 60 + minutes;
};
const displayDuration = (minutes: number) =>
  `${minutes >= 60 ? `${Math.floor(minutes / 60)} h${minutes % 60 ? ` ${minutes % 60} min` : ""}` : `${minutes} min`}`;
const recipeIngredients = (body: string) =>
  body
    .split(/^## Préparation\s*$/m)[0]
    .replace(/^## Ingrédients\s*$/m, "")
    .trim()
    .split("\n")
    .filter((line) => line.startsWith("- "))
    .map((line) => line.slice(2));
const recipes = (await getCollection("recipes"))
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map((recipe) => ({
    id: recipe.id,
    ...recipe.data,
    ingredients: recipeIngredients(recipe.body ?? ""),
    totalTime: displayDuration(
      durationMinutes(recipe.data.prep_time) +
        durationMinutes(recipe.data.cook_time),
    ),
    course: recipe.data.tags.find((tag) =>
      ["breakfast", "main", "side", "dessert"].includes(tag),
    )!,
  }));
const serializedRecipes = JSON.stringify(recipes).replace(/</g, "\\u003c");
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Une petite Collection ouverte de Recettes fiables pour tous les jours."
    />
    <title>Recettes</title>
  </head>
  <body>
    <a class="skip-link" href="#collection-results">Aller aux Recettes</a>
    <header class="site-header">
      <a href="/recipes/">Recettes</a><span>Cuisine du quotidien</span>
    </header>
    <main>
      <section class="collection" aria-labelledby="collection-title">
        <p class="eyebrow">La Collection</p>
        <h1 id="collection-title">Recettes du quotidien</h1>
        <div class="filters">
          <label class="search-label" for="recipe-search"
            >Rechercher une Recette</label
          >
          <input
            id="recipe-search"
            type="search"
            placeholder="Titre, résumé ou ingrédient"
            aria-describedby="collection-results"
          />
          <fieldset class="tag-filters">
            <legend>Filtrer par étiquette</legend>
            {
              controlledTags.map((tag) => (
                <label>
                  <input type="checkbox" value={tag} data-tag-filter />
                  {tagLabels[tag]}
                </label>
              ))
            }
          </fieldset>
        </div>
        <p id="collection-results" aria-live="polite"></p>
        <div id="empty-state" role="status" hidden>
          <p>Aucune Recette ne correspond à votre recherche.</p>
          <button type="button" id="reset-filters">Réinitialiser</button>
        </div>
        <ol class="recipe-cards">
          {
            recipes.map((recipe, index) => (
              <li data-recipe-item={index}>
                <a
                  id={`recipe-${recipe.id}`}
                  class="recipe-card"
                  data-recipe-card
                  data-recipe-url={`${import.meta.env.BASE_URL}/recipe/${recipe.id}/`}
                  href={`${import.meta.env.BASE_URL}/recipe/${recipe.id}/#recipe-${recipe.id}`}
                  aria-label={recipe.title}
                >
                  {recipe.image ? (
                    <img class="card-image" src={recipe.image} alt="" />
                  ) : (
                    <div class="image-placeholder" aria-hidden="true">
                      Photo à venir
                    </div>
                  )}
                  <div class="card-content">
                    <p class="card-meta">
                      {tagLabels[recipe.course]} · {recipe.totalTime}
                    </p>
                    <h2>{recipe.title}</h2>
                    <p>{recipe.summary}</p>
                    <p class="card-servings">
                      Pour {recipe.servings} personne
                      {recipe.servings === "1" ? "" : "s"}
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ol>
      </section>
    </main>
    <footer>
      Contenu des Recettes © contributeurs de Recettes, sous licence <a
        href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a
      >. Les modifications doivent être indiquées. <a
        href="https://github.com/romainbellande/recipes">Source</a
      >
    </footer>
    <script
      is:inline
      id="recipes-json"
      type="application/json"
      set:html={serializedRecipes}
    />
    <script>
      // @ts-nocheck
      import {
        collectionFiltersFromSearch,
        collectionSearchParams,
        matchingRecipeIndices,
      } from "../scripts/collection.js";

      const recipes = JSON.parse(
        document.querySelector("#recipes-json").textContent,
      );
      const search = document.querySelector("#recipe-search");
      const filters = [...document.querySelectorAll("[data-tag-filter]")];
      const results = document.querySelector("#collection-results");
      const emptyState = document.querySelector("#empty-state");
      const controlledTags = filters.map((filter) => filter.value);
      const initialFilters = collectionFiltersFromSearch(
        window.location.search,
        controlledTags,
      );
      search.value = initialFilters.query;
      filters.forEach((filter) => {
        filter.checked = initialFilters.selectedTags.includes(filter.value);
      });

      function updateCollection() {
        const selectedTags = filters
          .filter((filter) => filter.checked)
          .map((filter) => filter.value);
        const matches = matchingRecipeIndices(
          recipes,
          search.value,
          selectedTags,
        );
        document
          .querySelectorAll("[data-recipe-item]")
          .forEach((item, index) => {
            item.hidden = !matches.includes(index);
          });
        const hasMatches = matches.length > 0;
        results.textContent = hasMatches
          ? `${matches.length} Recette${matches.length === 1 ? "" : "s"}`
          : "Aucune Recette ne correspond à votre recherche.";
        emptyState.hidden = hasMatches;

        const parameters = collectionSearchParams(
          search.value,
          selectedTags,
          controlledTags,
        );
        const query = parameters.toString();
        document.querySelectorAll("[data-recipe-card]").forEach((card) => {
          card.href = `${card.dataset.recipeUrl}${query ? `?${query}` : ""}#${card.id}`;
        });
        history.replaceState(
          null,
          "",
          `${window.location.pathname}${query ? `?${query}` : ""}${window.location.hash}`,
        );
      }

      search.addEventListener("input", updateCollection);
      filters.forEach((filter) =>
        filter.addEventListener("change", updateCollection),
      );
      document.querySelector("#reset-filters").addEventListener("click", () => {
        search.value = "";
        filters.forEach((filter) => {
          filter.checked = false;
        });
        updateCollection();
        search.focus();
      });
      updateCollection();
      const originCard = document.getElementById(window.location.hash.slice(1));
      if (originCard?.matches("[data-recipe-card]")) originCard.focus();
    </script>
  </body>
</html>

<style>
  :root {
    color: #241b16;
    background: #fffaf4;
    font-family: Georgia, serif;
  }
  * {
    box-sizing: border-box;
  }
  [hidden] {
    display: none !important;
  }
  body {
    margin: 0;
  }
  a {
    color: inherit;
    text-underline-offset: 0.2em;
  }
  button,
  input {
    font: inherit;
  }
  button,
  a {
    cursor: pointer;
  }
  button:focus-visible,
  a:focus-visible,
  input:focus-visible {
    outline: 3px solid #005fcc;
    outline-offset: 3px;
  }
  .skip-link {
    position: absolute;
    left: 1rem;
    top: -4rem;
    background: white;
    padding: 0.75rem;
  }
  .skip-link:focus {
    top: 1rem;
  }
  .site-header,
  main,
  footer {
    max-width: 76rem;
    margin: auto;
    padding: 1.25rem 2rem;
  }
  .site-header,
  footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: system-ui, sans-serif;
  }
  .site-header a {
    font-weight: 800;
    text-decoration: none;
  }
  main {
    padding-top: 2rem;
  }
  .collection {
    display: grid;
    gap: 1rem;
  }
  .filters {
    max-width: 44rem;
  }
  .search-label,
  .tag-filters {
    display: block;
    margin: 1rem 0 0.5rem;
    font-family: system-ui, sans-serif;
    font-weight: 700;
  }
  #recipe-search {
    width: 100%;
    padding: 0.6rem;
    border: 1px solid #6b5d53;
  }
  .tag-filters {
    border: 0;
    padding: 0;
  }
  .tag-filters label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0.35rem 1rem 0.35rem 0;
    font-weight: 400;
  }
  #collection-results {
    margin: 0;
    font-family: system-ui, sans-serif;
  }
  #empty-state {
    margin: 0;
  }
  #reset-filters {
    border: 1px solid #803c20;
    background: transparent;
    color: #803c20;
    padding: 0.5rem 0.75rem;
  }
  .recipe-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }
  .recipe-card {
    display: block;
    background: #fff;
    color: inherit;
    text-decoration: none;
  }
  .card-image,
  .image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    min-height: 12rem;
  }
  .card-image {
    object-fit: cover;
  }
  .image-placeholder {
    display: grid;
    place-items: center;
    background: #e9dfd3;
    color: #6b5d53;
    font-family: system-ui, sans-serif;
  }
  .card-content {
    padding: 1.25rem;
  }
  .card-content p {
    line-height: 1.45;
  }
  .card-meta,
  .card-servings {
    margin: 0;
    color: #6b5d53;
    font-family: system-ui, sans-serif;
  }
  .card-meta {
    font-size: 0.85rem;
    font-weight: 700;
  }
  .card-content h2 {
    margin: 0.5rem 0;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.05;
  }
  .card-servings {
    font-weight: 700;
  }
  footer {
    border-top: 1px solid #d9cec2;
    margin-top: 4rem;
    font-size: 0.9rem;
    flex-wrap: wrap;
  }
  .eyebrow {
    margin: 0;
    color: #7b4b32;
    font:
      700 0.75rem system-ui,
      sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @media (max-width: 720px) {
    .site-header,
    main,
    footer {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .card-image,
    .image-placeholder {
      min-height: 0;
    }
  }
</style>
