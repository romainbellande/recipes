---
// THROWAWAY PROTOTYPE: three browse-and-cook layouts, switchable with ?variant=a|b|c.
const recipes = [
	{ title: 'Tomato, garlic & basil pasta', time: '30 min', tag: 'Weeknight', image: '🍅' },
	{ title: 'Lemony roast chicken', time: '1 hr 15 min', tag: 'Sunday', image: '🍋' },
	{ title: 'Crispy chickpea salad', time: '25 min', tag: 'Vegetarian', image: '🥬' },
];

const ingredients = ['300 g pasta', '400 g ripe tomatoes', '3 garlic cloves', 'A handful of basil', 'Olive oil, salt, and pepper'];
const steps = [
	['Set the pasta water to boil', 'Use a wide pot so the pasta has room to move. Salt the water well.'],
	['Make the tomato sauce', 'Soften sliced garlic in olive oil, add the tomatoes, and simmer until jammy.'],
	['Toss and finish', 'Move the pasta straight into the sauce with a splash of cooking water. Fold through basil.'],
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Browse and cook prototype</title>
	</head>
	<body>
		<main>
			<p class="prototype-note">Throwaway prototype — compare layouts with the control at the bottom.</p>

			<section class="variant" data-variant="a" aria-labelledby="variant-a-title">
				<header class="masthead">
					<a href="#collection" class="wordmark">The Weeknight Table</a>
					<a href="#recipe-a" class="text-link">Skip to today’s recipe</a>
				</header>
				<div class="hero">
					<p class="eyebrow">The collection</p>
					<h1 id="variant-a-title">Cook something good tonight.</h1>
					<p>Three unfussy recipes for the way a home cook actually chooses dinner: by time, mood, and what sounds good.</p>
				</div>
				<section id="collection" class="recipe-grid" aria-label="Recipe collection">
					{recipes.map((recipe, index) => (
						<article class:list={["recipe-card", { featured: index === 0 }]}>
							<div class="food-emoji" aria-hidden="true">{recipe.image}</div>
							<p class="eyebrow">{recipe.tag} · {recipe.time}</p>
							<h2>{recipe.title}</h2>
							<a href="#recipe-a">Read recipe<span class="sr-only">: {recipe.title}</span> →</a>
						</article>
					))}
				</section>
				<article id="recipe-a" class="recipe-sheet">
					<div>
						<p class="eyebrow">30 min · Serves 2</p>
						<h2>Tomato, garlic &amp; basil pasta</h2>
						<p>Bright, saucy pasta built from pantry staples and the ripest tomatoes you can find.</p>
						<a class="button" href="#method-a">Start cooking</a>
					</div>
					<aside aria-labelledby="ingredients-a"><h3 id="ingredients-a">You’ll need</h3><ul>{ingredients.map((item) => <li>{item}</li>)}</ul></aside>
				</article>
				<ol id="method-a" class="method">
					{steps.map(([title, detail], index) => <li><h3>{index + 1}. {title}</h3><p>{detail}</p></li>)}
				</ol>
			</section>

			<section class="variant" data-variant="b" hidden aria-labelledby="variant-b-title">
				<header class="masthead"><a href="#collection-b" class="wordmark">The Weeknight Table</a><button class="menu-button" type="button" aria-expanded="false">Collection menu</button></header>
				<div class="cookbook-layout">
					<nav id="collection-b" class="collection-nav" aria-label="Collection recipes">
						<p class="eyebrow">This collection</p><h2>Simple dinners</h2>
						<ol>{recipes.map((recipe, index) => <li><a class:list={{ selected: index === 0 }} href="#recipe-b"><span>{String(index + 1).padStart(2, '0')}</span>{recipe.title}<small>{recipe.time}</small></a></li>)}</ol>
					</nav>
					<article id="recipe-b" class="editorial-recipe">
						<p class="eyebrow">Recipe 01 · Weeknight</p><h1 id="variant-b-title">Tomato, garlic &amp; basil pasta</h1>
						<p class="dek">A dependable recipe page that treats the Collection as a small cookbook: easy to browse, then quiet when it’s time to cook.</p>
						<div class="recipe-meta"><span>30 min</span><span>Serves 2</span><span>Vegetarian</span></div>
						<div class="editorial-body">
							<aside aria-labelledby="ingredients-b"><h2 id="ingredients-b">Ingredients</h2><ul>{ingredients.map((item) => <li><label><input type="checkbox" /> {item}</label></li>)}</ul></aside>
							<div><h2>Method</h2>{steps.map(([title, detail], index) => <section class="method-step"><p class="step-number">{String(index + 1).padStart(2, '0')}</p><h3>{title}</h3><p>{detail}</p></section>)}</div>
						</div>
					</article>
				</div>
			</section>

			<section class="variant" data-variant="c" hidden aria-labelledby="variant-c-title">
				<header class="masthead"><a href="#cook-mode" class="wordmark">The Weeknight Table</a><a class="text-link" href="#recipe-c">Exit cook mode</a></header>
				<article id="cook-mode" class="cook-mode">
					<header><p class="eyebrow">Now cooking · 30 min total</p><h1 id="variant-c-title">Tomato, garlic &amp; basil pasta</h1><p>Keep this page open on the counter. Everything nonessential steps aside.</p></header>
					<div class="cook-columns">
						<aside class="progress-panel" aria-label="Recipe progress"><p class="eyebrow">Your progress</p><ol>{steps.map(([title], index) => <li class:list={{ current: index === 0 }}><a href={`#step-${index + 1}`}>{index + 1}. {title}</a></li>)}</ol><details><summary>Ingredients</summary><ul>{ingredients.map((item) => <li><label><input type="checkbox" /> {item}</label></li>)}</ul></details></aside>
						<div id="recipe-c" class="active-step">
							<p id="cook-status" class="sr-only" aria-live="polite"></p>
							{steps.map(([title, detail], index) => <section id={`step-${index + 1}`} class:list={{ current: index === 0 }}><p class="step-number">Step {index + 1} of {steps.length}</p><h2>{title}</h2><p>{detail}</p><button type="button">{index === steps.length - 1 ? 'Finish recipe' : 'Mark step complete'}</button></section>)}
						</div>
					</div>
				</article>
			</section>
		</main>

		<nav class="prototype-switcher" aria-label="Prototype variant">
			<button type="button" data-direction="-1" aria-label="Previous variant">←</button>
			<output aria-live="polite" aria-atomic="true">A — Collection-first</output>
			<button type="button" data-direction="1" aria-label="Next variant">→</button>
		</nav>

		<script>
			const variants = [
				{ key: 'a', name: 'Collection-first' },
				{ key: 'b', name: 'Cookbook' },
				{ key: 'c', name: 'Cook mode' },
			];
			const panels = [...document.querySelectorAll<HTMLElement>('[data-variant]')];
			const status = document.querySelector('output')!;

			function showVariant(key: string) {
				const current = variants.findIndex((variant) => variant.key === key);
				const index = current < 0 ? 0 : current;
				const variant = variants[index];
				panels.forEach((panel) => (panel.hidden = panel.dataset.variant !== variant.key));
				status.textContent = `${variant.key.toUpperCase()} — ${variant.name}`;
				const url = new URL(window.location.href);
				url.searchParams.set('variant', variant.key);
				history.replaceState(null, '', url);
			}

			function move(direction: number) {
				const current = new URLSearchParams(window.location.search).get('variant');
				const index = Math.max(0, variants.findIndex((variant) => variant.key === current));
				showVariant(variants[(index + direction + variants.length) % variants.length].key);
			}

			document.querySelectorAll<HTMLButtonElement>('[data-direction]').forEach((button) =>
				button.addEventListener('click', () => move(Number(button.dataset.direction))),
			);
			document.addEventListener('keydown', (event) => {
				if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
				if (event.target instanceof HTMLElement && event.target.closest('input, textarea, [contenteditable="true"]')) return;
				move(event.key === 'ArrowLeft' ? -1 : 1);
			});

			const cookSteps = [...document.querySelectorAll<HTMLElement>('#recipe-c section')];
			const progress = [...document.querySelectorAll<HTMLElement>('.progress-panel li')];
			const cookStatus = document.querySelector('#cook-status')!;
			function showStep(index: number) {
				cookSteps.forEach((step, stepIndex) => (step.classList.toggle('current', stepIndex === index)));
				progress.forEach((item, stepIndex) => item.classList.toggle('current', stepIndex === index));
				cookStatus.textContent = index === cookSteps.length - 1 ? 'Final step. Finish the recipe when ready.' : `Step ${index + 1} of ${cookSteps.length}: ${cookSteps[index].querySelector('h2')?.textContent}.`;
			}
			cookSteps.forEach((step, index) => step.querySelector('button')?.addEventListener('click', () => {
				if (index === cookSteps.length - 1) cookStatus.textContent = 'Recipe complete.';
				else showStep(index + 1);
			}));
			showVariant(new URLSearchParams(window.location.search).get('variant') ?? 'a');
			showStep(0);
		</script>
	</body>
</html>

<style>
	:root { color: #251d18; background: #fbf7f1; font-family: Georgia, serif; }
	* { box-sizing: border-box; }
	body { margin: 0; }
	main { max-width: 1100px; margin: auto; padding: 1.5rem 2rem 7rem; }
	a { color: inherit; text-underline-offset: 0.2em; }
	button, .button { cursor: pointer; font: inherit; }
	button:focus-visible, a:focus-visible, input:focus-visible { outline: 3px solid #005fcc; outline-offset: 3px; }
	.sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
	.prototype-note { margin: 0 0 2rem; color: #685a51; font: 0.85rem system-ui, sans-serif; }
	.masthead { display: flex; justify-content: space-between; align-items: center; gap: 1rem; border-bottom: 1px solid #cfc4b8; padding-bottom: 1rem; }
	.wordmark { font-weight: bold; text-decoration: none; }
	.text-link { font: 0.9rem system-ui, sans-serif; }
	.eyebrow, .step-number { color: #786553; font: 700 0.75rem system-ui, sans-serif; letter-spacing: 0.08em; text-transform: uppercase; }
	.hero { max-width: 44rem; padding: 4rem 0 2rem; }
	h1 { font-size: clamp(2.4rem, 6vw, 5.5rem); line-height: 0.95; margin: 0.25rem 0 1rem; }
	h2 { line-height: 1.05; }
	.hero > p:last-child, .dek, .active-step > section > p { font-size: 1.2rem; line-height: 1.55; }
	.recipe-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
	.recipe-card { background: #efe7dc; padding: 1.25rem; min-height: 17rem; display: flex; flex-direction: column; }
	.recipe-card.featured { background: #d6e2bb; }
	.food-emoji { font-size: 3.5rem; margin: auto 0 1rem; }
	.recipe-card a { margin-top: auto; font-family: system-ui, sans-serif; }
	.recipe-sheet { display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; background: #fffdf9; margin-top: 4rem; padding: clamp(1.5rem, 5vw, 4rem); }
	.recipe-sheet h2 { font-size: clamp(2rem, 4vw, 4rem); margin-top: 0; }
	.button { display: inline-block; background: #251d18; color: white; padding: 0.75rem 1rem; text-decoration: none; }
	.recipe-sheet aside, .editorial-body aside { border-top: 2px solid #251d18; }
	li { margin: 0.6rem 0; }
	.method { max-width: 44rem; margin: 3rem auto; }
	.method li { margin: 2rem 0; }
	.menu-button { background: none; border: 1px solid; padding: 0.5rem; }
	.cookbook-layout { display: grid; grid-template-columns: minmax(12rem, 0.6fr) 2fr; gap: clamp(2rem, 7vw, 7rem); padding-top: 3rem; }
	.collection-nav h2 { font-size: 2rem; }
	.collection-nav ol { list-style: none; padding: 0; }
	.collection-nav a { display: grid; grid-template-columns: 2rem 1fr; gap: 0.5rem; text-decoration: none; padding: 0.8rem 0; border-top: 1px solid #cfc4b8; }
	.collection-nav .selected { font-weight: bold; }
	.collection-nav small { grid-column: 2; color: #786553; }
	.editorial-recipe { max-width: 48rem; }
	.recipe-meta { display: flex; gap: 1rem; font: 0.9rem system-ui, sans-serif; margin: 2rem 0; }
	.editorial-body { display: grid; grid-template-columns: minmax(11rem, 0.7fr) 1.5fr; gap: 3rem; }
	.editorial-body ul, .progress-panel ul { list-style: none; padding: 0; }
	.method-step { border-top: 1px solid #cfc4b8; padding: 0.75rem 0 1.5rem; }
	.method-step h3 { margin: 0; }
	.cook-mode { max-width: 60rem; margin: 3rem auto; }
	.cook-mode header { border-left: 5px solid #bd493a; padding-left: 1.25rem; }
	.cook-columns { display: grid; grid-template-columns: minmax(13rem, 0.7fr) 2fr; gap: 3rem; margin-top: 3rem; }
	.progress-panel { font-family: system-ui, sans-serif; }
	.progress-panel ol { list-style: none; padding: 0; }
	.progress-panel li { border-left: 2px solid #cfc4b8; padding: 0.5rem 0 0.5rem 1rem; }
	.progress-panel li.current { border-color: #bd493a; font-weight: bold; }
	.progress-panel a { text-decoration: none; }
	.progress-panel details { margin-top: 2rem; }
	.active-step > section { display: none; min-height: 22rem; background: #fffdf9; padding: clamp(1.5rem, 6vw, 5rem); }
	.active-step > section.current { display: block; }
	.active-step button { background: #bd493a; color: white; border: 0; padding: 0.75rem 1rem; }
	.prototype-switcher { position: fixed; bottom: 1rem; left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 1rem; background: #251d18; color: white; border-radius: 999px; padding: 0.5rem; box-shadow: 0 4px 18px #0005; font-family: system-ui, sans-serif; }
	.prototype-switcher button { width: 2.25rem; height: 2.25rem; border: 0; border-radius: 50%; background: white; color: #251d18; font-size: 1.2rem; }
	.prototype-switcher output { min-width: 11rem; text-align: center; }
	@media (max-width: 680px) { main { padding: 1rem 1rem 6rem; } .recipe-grid, .recipe-sheet, .cookbook-layout, .editorial-body, .cook-columns { grid-template-columns: 1fr; } .recipe-card { min-height: auto; } .food-emoji { margin: 0 0 1rem; } .prototype-switcher { width: calc(100% - 2rem); justify-content: space-between; } }
</style>
